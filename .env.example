# GreenOps CI/CD Pipeline Configuration
# ======================================
# Copy this file to .env and fill in your actual keys.
# DO NOT commit the .env file to GitHub.

# --- LLM API Keys ---
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- GitHub Integration ---
# Required for PR analytics and LOC counting.
GITHUB_TOKEN=your_github_personal_access_token_here

# --- Carbon Intelligence ---
# Required for live grid intensity tracking.
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# --- App Settings ---
DASHBOARD_PORT=5001
DEFAULT_CARBON_ZONE=IN-SO
